PORT=3003
SERVICE_NAME=inventory-service

DATABASE_URL=postgresql://ecommerce:ecommerce@localhost:5432/inventory_service?schema=public

KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=inventory-service
KAFKA_CONSUMER_GROUP=inventory-service

OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=50

# Unknown products are auto-created with this much stock on first sight.
# Order a quantity greater than this to exercise the OUT_OF_STOCK saga path.
DEFAULT_STOCK=100
