PORT=3002
SERVICE_NAME=payment-service

DATABASE_URL=postgresql://ecommerce:ecommerce@localhost:5432/payment_service?schema=public

KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=payment-service
KAFKA_CONSUMER_GROUP=payment-service

OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=50

# Demo trigger: orders whose total (in cents) ends in this value are DECLINED,
# so you can exercise the saga failure path on demand (like a test card).
DECLINE_WHEN_CENTS_ENDS_IN=13

# Consumer retry policy: attempts before a poison message is routed to <aggregate>.DLQ
CONSUMER_MAX_RETRIES=3
CONSUMER_RETRY_BACKOFF_MS=500
