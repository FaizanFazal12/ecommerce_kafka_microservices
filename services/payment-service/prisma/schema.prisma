// Payment Service data model.
// Owns payments + its own outbox and consumer-dedup tables (Layers 2 & 3).

generator client {
  provider = "prisma-client-js"
  // Service-local output so each service owns its own client (see ADR / monorepo note).
  output = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentStatus {
  COMPLETED
  FAILED
}

model Payment {
  id          String        @id @default(uuid()) @db.Uuid
  orderId     String        @unique @db.Uuid // one payment per order (idempotency anchor)
  customerId  String        @db.Uuid
  amountCents Int
  status      PaymentStatus
  failureCode String? // CARD_DECLINED | INSUFFICIENT_FUNDS | GATEWAY_ERROR
  createdAt   DateTime      @default(now())

  @@map("payments")
}

// Layer 2 — transactional outbox
model OutboxEvent {
  id            String    @id @default(uuid()) @db.Uuid
  aggregateType String
  aggregateId   String    @db.Uuid
  topic         String
  partitionKey  String
  eventType     String
  payload       Json
  createdAt     DateTime  @default(now())
  publishedAt   DateTime?

  @@index([publishedAt, createdAt])
  @@map("outbox_events")
}

// Layer 3 — consumer dedup
model ProcessedEvent {
  eventId     String   @db.Uuid
  consumer    String
  processedAt DateTime @default(now())

  @@id([eventId, consumer])
  @@map("processed_events")
}
