PORT=3004
SERVICE_NAME=notification-service

DATABASE_URL=postgresql://ecommerce:ecommerce@localhost:5432/notification_service?schema=public

KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=notification-service
