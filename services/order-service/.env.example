# Copy to .env and adjust for local runs.
# When running inside docker-compose, host names become service names (postgres, kafka, redis).

PORT=3001
SERVICE_NAME=order-service

# Postgres (the order-service database created by infra/postgres/init)
DATABASE_URL=postgresql://ecommerce:ecommerce@localhost:5432/order_service?schema=public

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=order-service
KAFKA_CONSUMER_GROUP=order-service

# Redis (idempotency fast-path cache)
REDIS_URL=redis://localhost:6379

# Outbox relay polling interval (ms)
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=50

# Idempotency key TTL (seconds) for the Redis fast-path
IDEMPOTENCY_TTL_SECONDS=86400

# Consumer retry policy: attempts before a poison message is routed to <aggregate>.DLQ
CONSUMER_MAX_RETRIES=3
CONSUMER_RETRY_BACKOFF_MS=500
