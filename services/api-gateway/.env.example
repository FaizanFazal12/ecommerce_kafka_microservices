PORT=3000
SERVICE_NAME=api-gateway

# Downstream services
ORDER_SERVICE_URL=http://localhost:3001

# Redis (rate-limit counters)
REDIS_URL=redis://localhost:6379

# Auth (demo JWT signing — use a real secret manager in production)
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN=1h

# Rate limit: max requests per window (seconds), per authenticated customer (or IP)
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_SECONDS=10
